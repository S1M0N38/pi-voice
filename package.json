{
  "name": "pi-voice",
  "version": "0.1.0",
  "description": "HTTP server for Kokoro TTS — text-to-speech via ONNX inference.",
  "type": "module",
  "license": "MIT",
  "author": "S1M0N38",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "tts",
    "kokoro",
    "speech-synthesis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/S1M0N38/pi-voice"
  },
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "!.github"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --import jiti extensions/server.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "server": "node --import jiti extensions/server.ts"
  },
  "dependencies": {
    "jiti": "^2.4.2",
    "kokoro-js": "^1.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@mariozechner/pi-coding-agent": "^0.70.0",
    "typebox": "^1.1.24",
    "typescript": "^5.0.0"
  }
}
